  "gp16": {
   "title": "Engine Warnings",
   "params": {
    "pwrloss": {
     "abbr": "PWRLOSS",
     "description": "POWER LOSS OUTPUT 1",
     "trigger": "When NG-NG2 > 7% or Q1-Q2>45% or NF1-NF2 >5% or\nany corss talk failure or GOV warning, Warning is ON",
     "discrete": true
    },
    "scr1usesh": {
     "abbr": "SCR1USE_SH",
     "description": "SCR1 Use (Super Contingency Rating)",
     "trigger": "Thermal  counter  use  will be logged as SCR use when NG  exceeds 104.8 % or T45 exceeds 1251  DEG K  whichever limit is reached  first.",
     "discrete": true
    },
    "mcr1usesh": {
     "abbr": "mcr1use_sh",
     "description": "MCR1 Use  (Maximum Contingency Rating)",
     "trigger": "Thermal  counter  use  will be logged as MCR use when NG  exceeds 102 % or T45 exceeds 1215 DEG K  whichever limit is reached  first.",
     "discrete": true
    },
    "mcr2usesh": {
     "abbr": "mcr2use_sh",
     "description": "MCR2 Use  (Maximum Contingency Rating)",
     "trigger": "Thermal  counter  use  will be logged as MCR use when NG  exceeds 102 % or T45 exceeds 1215 DEG K  whichever limit is reached  first.",
     "discrete": true
    },
    "gov1sh": {
     "abbr": "gov1-sh",
